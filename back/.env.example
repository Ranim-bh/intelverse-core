GROQ_API_KEY=your_groq_api_key_here
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intelverse
# Or configure individually instead of DATABASE_URL:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=intelverse
# PG_SSL=false
# Optional: table name used by /api/generate-offer for services list
# SERVICES_TABLE_KEY=services
# Optional: comma-separated PostgreSQL tables to expose via /api/tables
# TABLES_LIST=guest_kpis,room_kpi,service,users
